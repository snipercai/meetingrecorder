# LLM API Configuration
LLM_API_BASE_URL=http://your-llm-api-url/chat/completions
LLM_API_KEY=your-api-key-here
LLM_API_MODEL=your-model-name-here

# LLM Mode
LLM_MODE=api

# ASR Configuration
ASR_MODEL_PATH=Qwen/Qwen3-ASR-0.6B
ASR_DEVICE=auto

# Web Configuration
WEB_HOST=0.0.0.0
WEB_PORT=8080

# Summary Configuration
SUMMARY_INTERVAL=60